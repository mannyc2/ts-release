{
  "$schema": "https://mannyc2.github.io/ts-release/schema/release-config.schema.json",
  "identity": {
    "name": "@mannyc1/ts-release",
    "version": "0.0.2",
    "commit": "HEAD",
    "tag": "v0.0.2",
    "notes": "Initial release of the plan-first release package."
  },
  "artifacts": [
    {
      "id": "npm-package",
      "path": ".",
      "format": "directory",
      "consumers": ["npm"]
    },
    {
      "id": "package-tarball",
      "path": ".release/artifacts/mannyc1-ts-release-0.0.2.tgz",
      "format": "tarball",
      "consumers": ["github"]
    },
    {
      "id": "cli-linux-x64",
      "path": ".release/artifacts/ts-release-0.0.2-linux-x64",
      "format": "file",
      "consumers": ["github"]
    },
    {
      "id": "cli-linux-arm64",
      "path": ".release/artifacts/ts-release-0.0.2-linux-arm64",
      "format": "file",
      "consumers": ["github"]
    },
    {
      "id": "cli-darwin-x64",
      "path": ".release/artifacts/ts-release-0.0.2-darwin-x64",
      "format": "file",
      "consumers": ["github"]
    },
    {
      "id": "cli-darwin-arm64",
      "path": ".release/artifacts/ts-release-0.0.2-darwin-arm64",
      "format": "file",
      "consumers": ["github"]
    },
    {
      "id": "cli-windows-x64",
      "path": ".release/artifacts/ts-release-0.0.2-windows-x64.exe",
      "format": "file",
      "consumers": ["github"]
    }
  ],
  "targets": [
    {
      "_tag": "NpmRegistryTarget",
      "id": "npm",
      "registry": "https://registry.npmjs.org",
      "packageName": "@mannyc1/ts-release",
      "packagePath": ".",
      "trustedPublishing": {
        "provider": "github-actions",
        "workflow": "release.yml",
        "packageExists": true,
        "verifyPackageExists": true
      },
      "access": "public",
      "provenance": true,
      "dryRunSupport": "native",
      "mutability": "immutable",
      "recovery": "publish-new-version"
    },
    {
      "_tag": "GitHubReleaseTarget",
      "id": "github",
      "repository": "mannyc2/ts-release",
      "tokenEnv": "GH_TOKEN",
      "draft": false,
      "prerelease": false,
      "dryRunSupport": "simulated",
      "mutability": "mutable-release",
      "recovery": "delete-and-recreate"
    }
  ],
  "strict": true,
  "evidenceDirectory": ".release/evidence/{version}"
}
