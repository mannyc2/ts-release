{
  "$schema": "https://mannyc2.github.io/ts-release/schema/release-config.schema.json",
  "project": {
    "name": "release-example-github",
    "packageName": "release-example-github",
    "version": "0.1.0",
    "commit": "example",
    "tag": "v0.1.0",
    "notes": "Example GitHub release"
  },
  "build": {
    "artifacts": [
      {
        "id": "archive",
        "path": "artifacts/release-example-github-0.1.0.tgz",
        "format": "tarball",
        "consumers": [
          "github"
        ]
      }
    ]
  },
  "publish": {
    "github": {
      "repository": "owner/repo",
      "tokenEnv": "GH_TOKEN",
      "draft": true,
      "prerelease": false
    }
  },
  "strict": true,
  "evidence": ".release/evidence"
}
