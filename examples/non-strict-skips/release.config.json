{
  "identity": {
    "name": "release-example-skips",
    "version": "0.1.0",
    "commit": "example",
    "tag": "v0.1.0"
  },
  "artifacts": [
    {
      "id": "archive",
      "path": "artifacts/release-example-skips-0.1.0.tgz",
      "format": "tarball",
      "consumers": ["github"]
    }
  ],
  "targets": [
    {
      "_tag": "GitHubReleaseTarget",
      "id": "github",
      "repository": "owner/repo",
      "tokenEnv": "GH_TOKEN",
      "draft": true,
      "dryRunSupport": "none",
      "mutability": "mutable-release",
      "recovery": "manual"
    }
  ],
  "strict": false,
  "evidenceDirectory": ".release/evidence"
}
