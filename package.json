{
  "name": "@mannyc1/ts-release",
  "version": "0.0.7",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "Portable artifact and package-manager distribution planning for TypeScript projects.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mannyc2/ts-release.git"
  },
  "homepage": "https://github.com/mannyc2/ts-release#readme",
  "bugs": {
    "url": "https://github.com/mannyc2/ts-release/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "ts-release",
    "publishing",
    "effect",
    "bun",
    "cli"
  ],
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "bin": {
    "ts-release": "./apps/release-ts/src/cli/main.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "ARCHITECTURE.md",
    "apps/release-ts/src",
    "dist",
    "examples",
    "src",
    "templates",
    "SPEC.md",
    "README.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "bun run scripts/clean-dist.ts && tsc -p tsconfig.build.json",
    "test": "bun test",
    "test:integration:tools": "RELEASE_INTEGRATION_TOOLS=1 bun test integration-tools.test.ts",
    "test:integration:github": "RELEASE_INTEGRATION_TOOLS=1 RELEASE_INTEGRATION_GITHUB=1 bun test integration-tools.test.ts",
    "test:coverage": "bun test --coverage",
    "check:package-exports": "bun run scripts/check-package-exports.ts",
    "check:effect-imports": "bun run scripts/check-effect-imports.ts",
    "check:tree-shaking": "bun run scripts/check-tree-shaking.ts",
    "check:examples": "bun run scripts/check-examples.ts",
    "check:readme": "bun run scripts/check-readme.ts",
    "check:self-release-config": "bun run apps/release-ts/scripts/check-self-release-config.ts",
    "check:self-release-doctor": "bun run cli doctor --config apps/release-ts/release.config.json --format text",
    "check:self-release-live": "bun run apps/release-ts/scripts/check-self-release-live-readiness.ts",
    "check:self-release-artifacts": "bun run apps/release-ts/scripts/check-self-release-artifacts.ts",
    "check:action-bundle": "bun run scripts/check-action-bundle.ts",
    "check:core": "bun run check && bun test && bun audit && bun run check:effect-imports && bun run check:tree-shaking && bun run build && bun run check:examples && bun run check:readme && bun run check:package-exports",
    "check:app": "bun run --cwd apps/release-ts check && bun test test/cli-command.test.ts",
    "check:action": "bun run --cwd apps/ts-release-action check && bun run check:action-bundle && bun test test/action-command.test.ts",
    "check:portable": "bun run check:core && bun run check:app && bun run check:action",
    "check:release": "bun run check:self-release-config && bun run check:self-release-doctor && bun run check:portable",
    "release:artifacts": "bun run cli build --config apps/release-ts/release.config.json --format text",
    "cli": "bun run apps/release-ts/src/cli/main.ts"
  },
  "dependencies": {
    "effect": "4.0.0-beta.83",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@effect/bun-test": "file:vendor/effect-bun-test",
    "@effect/platform-bun": "4.0.0-beta.83",
    "@types/bun": "^1.3.14",
    "@types/semver": "^7.7.1",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
