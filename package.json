{
  "name": "@mannyc1/ts-release",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "Plan-first release orchestration with explicit validation, evidence, and execution gates.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mannyc2/ts-release.git"
  },
  "homepage": "https://github.com/mannyc2/ts-release#readme",
  "bugs": {
    "url": "https://github.com/mannyc2/ts-release/issues"
  },
  "keywords": [
    "ts-release",
    "publishing",
    "effect",
    "bun",
    "cli"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "bin": {
    "release": "dist/cli/main.js"
  },
  "sideEffects": [
    "./dist/cli/main.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/command.d.ts",
      "default": "./dist/cli/command.js"
    },
    "./cli/command": {
      "types": "./dist/cli/command.d.ts",
      "default": "./dist/cli/command.js"
    },
    "./cli/programmatic": {
      "types": "./dist/cli/programmatic.d.ts",
      "default": "./dist/cli/programmatic.js"
    },
    "./config/errors": {
      "types": "./dist/config/errors.d.ts",
      "default": "./dist/config/errors.js"
    },
    "./config/load": {
      "types": "./dist/config/load.d.ts",
      "default": "./dist/config/load.js"
    },
    "./config/schema": {
      "types": "./dist/config/schema.d.ts",
      "default": "./dist/config/schema.js"
    },
    "./domain/artifact": {
      "types": "./dist/domain/artifact.d.ts",
      "default": "./dist/domain/artifact.js"
    },
    "./domain/evidence": {
      "types": "./dist/domain/evidence.d.ts",
      "default": "./dist/domain/evidence.js"
    },
    "./domain/operation": {
      "types": "./dist/domain/operation.d.ts",
      "default": "./dist/domain/operation.js"
    },
    "./domain/release": {
      "types": "./dist/domain/release.d.ts",
      "default": "./dist/domain/release.js"
    },
    "./domain/target": {
      "types": "./dist/domain/target.d.ts",
      "default": "./dist/domain/target.js"
    },
    "./host": {
      "types": "./dist/host/host.d.ts",
      "default": "./dist/host/host.js"
    },
    "./host/bun": {
      "types": "./dist/host/bun.d.ts",
      "default": "./dist/host/bun.js"
    },
    "./host/test": {
      "types": "./dist/host/test.d.ts",
      "default": "./dist/host/test.js"
    },
    "./planner/create-release-plan": {
      "types": "./dist/planner/create-release-plan.d.ts",
      "default": "./dist/planner/create-release-plan.js"
    },
    "./planner/errors": {
      "types": "./dist/planner/errors.d.ts",
      "default": "./dist/planner/errors.js"
    },
    "./planner/evidence-recorder": {
      "types": "./dist/planner/evidence-recorder.d.ts",
      "default": "./dist/planner/evidence-recorder.js"
    },
    "./planner/executor": {
      "types": "./dist/planner/executor.d.ts",
      "default": "./dist/planner/executor.js"
    },
    "./planner/normalize-release": {
      "types": "./dist/planner/normalize-release.d.ts",
      "default": "./dist/planner/normalize-release.js"
    },
    "./planner/render-plan": {
      "types": "./dist/planner/render-plan.d.ts",
      "default": "./dist/planner/render-plan.js"
    },
    "./targets/adapter": {
      "types": "./dist/targets/adapter.d.ts",
      "default": "./dist/targets/adapter.js"
    },
    "./targets/github": {
      "types": "./dist/targets/github.d.ts",
      "default": "./dist/targets/github.js"
    },
    "./targets/homebrew": {
      "types": "./dist/targets/homebrew.d.ts",
      "default": "./dist/targets/homebrew.js"
    },
    "./targets/live": {
      "types": "./dist/targets/live.d.ts",
      "default": "./dist/targets/live.js"
    },
    "./targets/npm": {
      "types": "./dist/targets/npm.d.ts",
      "default": "./dist/targets/npm.js"
    },
    "./targets/registry": {
      "types": "./dist/targets/registry.d.ts",
      "default": "./dist/targets/registry.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "SPEC.md",
    "README.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "bun run scripts/clean-dist.ts && tsc -p tsconfig.build.json",
    "test": "bun test",
    "test:integration:tools": "RELEASE_INTEGRATION_TOOLS=1 bun test integration-tools.test.ts",
    "test:integration:github": "RELEASE_INTEGRATION_TOOLS=1 RELEASE_INTEGRATION_GITHUB=1 bun test integration-tools.test.ts",
    "test:coverage": "bun test --coverage",
    "check:package-exports": "bun run scripts/check-package-exports.ts",
    "check:effect-imports": "bun run scripts/check-effect-imports.ts",
    "check:tree-shaking": "bun run scripts/check-tree-shaking.ts",
    "check:examples": "bun run scripts/check-examples.ts",
    "check:self-release-config": "bun run scripts/check-self-release-config.ts",
    "check:portable": "bun run check && bun test && bun audit && bun run check:effect-imports && bun run check:tree-shaking && bun run build && bun run check:examples && bun run check:package-exports && bun dist/cli/main.js --help",
    "check:release": "bun run check:self-release-config && bun run check:portable",
    "cli": "bun run src/cli/main.ts"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.83",
    "effect": "4.0.0-beta.83"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
