{
  "$schema": "https://mannyc2.github.io/ts-release/schema/release-config.schema.json",
  "project": {
    "name": "@scope/pkg",
    "packageName": "@scope/pkg",
    "version": "0.1.0",
    "commit": "abc123",
    "tag": "v0.1.0"
  },
  "build": {
    "bun": {
      "id": "cli",
      "entry": "src/cli.ts",
      "outputs": [
        {
          "id": "cli-linux-x64",
          "target": "bun-linux-x64-baseline",
          "path": "artifacts/pkg-{version}-linux-x64",
          "consumers": [
            "github"
          ]
        },
        {
          "id": "cli-linux-arm64",
          "target": "bun-linux-arm64",
          "path": "artifacts/pkg-{version}-linux-arm64",
          "consumers": [
            "github"
          ]
        },
        {
          "id": "cli-darwin-x64",
          "target": "bun-darwin-x64",
          "path": "artifacts/pkg-{version}-darwin-x64",
          "consumers": [
            "github"
          ]
        },
        {
          "id": "cli-darwin-arm64",
          "target": "bun-darwin-arm64",
          "path": "artifacts/pkg-{version}-darwin-arm64",
          "consumers": [
            "github"
          ]
        },
        {
          "id": "cli-windows-x64",
          "target": "bun-windows-x64-baseline",
          "path": "artifacts/pkg-{version}-windows-x64.exe",
          "consumers": [
            "github"
          ]
        }
      ]
    },
    "npmPackage": {
      "id": "package",
      "path": ".",
      "consumers": [
        "npm"
      ]
    }
  },
  "publish": {
    "npm": {
      "registry": "https://registry.npmjs.org",
      "packageName": "@scope/pkg",
      "packagePath": ".",
      "trustedPublishing": {
        "provider": "github-actions",
        "workflow": "release.yml",
        "packageExists": true,
        "verifyPackageExists": true
      },
      "access": "public",
      "provenance": true
    },
    "github": {
      "repository": "owner/repo",
      "tokenEnv": "GH_TOKEN",
      "draft": true,
      "prerelease": false
    }
  },
  "strict": true,
  "evidence": ".release/evidence/{version}"
}
