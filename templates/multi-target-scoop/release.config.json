{
  "$schema": "https://mannyc2.github.io/ts-release/schema/release-config.schema.json",
  "project": {
    "name": "@scope/pkg",
    "packageName": "@scope/pkg",
    "version": "0.1.0",
    "commit": "abc123",
    "tag": "v0.1.0"
  },
  "build": {
    "npmPackage": {
      "id": "package",
      "path": ".",
      "consumers": [
        "npm"
      ]
    },
    "artifacts": [
      {
        "id": "archive",
        "path": "artifacts/pkg-0.1.0.zip",
        "format": "zip",
        "consumers": [
          "github",
          "scoop"
        ]
      }
    ]
  },
  "publish": {
    "npm": {
      "registry": "https://registry.npmjs.org",
      "packageName": "@scope/pkg",
      "packagePath": ".",
      "trustedPublishing": {
        "provider": "github-actions",
        "workflow": "release.yml",
        "packageExists": true,
        "verifyPackageExists": true
      },
      "access": "public",
      "provenance": true
    },
    "github": {
      "repository": "owner/repo",
      "tokenEnv": "GH_TOKEN",
      "draft": true,
      "prerelease": false
    },
    "scoop": {
      "repository": "owner/scoop-bucket",
      "manifestName": "pkg",
      "manifestPath": ".release/generated/pkg.json",
      "artifactId": "archive",
      "homepage": "https://github.com/owner/repo",
      "description": "Example Scoop manifest for pkg",
      "license": "MIT",
      "url": "https://github.com/owner/repo/releases/download/v0.1.0/pkg-0.1.0.zip",
      "bin": "pkg.exe"
    }
  },
  "strict": true,
  "evidence": ".release/evidence/{version}"
}
