{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@mannyc1/ts-release": ["src/index.ts"],
      "@mannyc1/ts-release/host": ["src/host/host.ts"],
      "@mannyc1/ts-release/workflows": ["src/workflows/index.ts"],
      "@mannyc1/ts-release/*": ["src/*.ts"]
    },
    "types": ["bun-types"],
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "test/**/*.ts", "scripts/**/*.ts", "bunfig.toml"],
  "exclude": ["dist", ".repos", "node_modules"]
}
